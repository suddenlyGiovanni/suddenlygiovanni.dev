		"@suddenly-giovanni/ui": "workspace:*",
		"cookie": "1.0.2",
		"effect": "3.13.1",
		"hono": "^4.6.11",
		"isbot": "5.1.22",
		"react": "~19.0.0",
		"react-dom": "~19.0.0",
		"react-router": "7.1.5",
		"react-router-hono-server": "2.8.5",
		"remix-utils": "8.1.0",
		"vite-plugin-babel": "1.3.0"
	},
	"devDependencies": {
		"@babel/preset-typescript": "7.26.0",
		"@mdx-js/rollup": "3.1.0",
		"@react-router/dev": "7.1.5",
		"@suddenly-giovanni/config-typescript": "workspace:*",
		"@suddenly-giovanni/eslint-config": "workspace:*",
		"@tailwindcss/typography": "0.5.16",
		"@tailwindcss/vite": "4.0.6",
		"@total-typescript/ts-reset": "0.6.1",
		"@types/mdx": "2.0.13",
		"@types/node": "22.13.4",
		"@types/react": "19.0.10",
		"@types/react-dom": "19.0.4",
		"@vitest/coverage-v8": "3.0.5",
		"@vitest/eslint-plugin": "1.1.28",
		"@vitest/ui": "3.0.5",
		"babel-plugin-react-compiler": "19.0.0-beta-e552027-20250112",

		"msw": "2.7.0",

		"react-router-devtools": "2.0.0-beta.0",
		"tailwindcss": "4.0.6",
		"tailwindcss-animate": "1.0.7",
		"vite": "6.1.0",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.0.5"
	},
	"name": "@suddenly-giovanni/app",
	"private": true,
	"scripts": {
		"build": "react-router build",
		"check": "biome check .",
		"check:fix": "biome check --apply .",
		"clean": "scripty",
		"dev": "react-router dev",
		"format": "biome check --vcs-enabled=true --vcs-use-ignore-file=true  --formatter-enabled=true --linter-enabled=false --organize-imports-enabled=true .",
		"format:write": "biome check --vcs-enabled=true --vcs-use-ignore-file=true  --formatter-enabled=true --linter-enabled=false --organize-imports-enabled=true --write .",
		"lint": "biome ci --vcs-enabled=true --vcs-use-ignore-file=true --vcs-root='../../' --formatter-enabled=false --linter-enabled=true --organize-imports-enabled=false --no-errors-on-unmatched .",
		"start": "node --env-file=.production.env build/server/index.js",
		"test": "vitest",
		"test:unit": "vitest",
		"typecheck": "react-router typegen && tsc"
	},
	"sideEffects": false,
	"type": "module"
}
